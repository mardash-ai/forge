# Forge DATA PLANE image  →  ghcr.io/mardash-ai/forge-data-plane
#
# The production/runtime image. It serves ONLY the data-plane capabilities
# (scheduler + secrets store + read/observe surfaces) and carries NO developer
# dependencies: no Docker CLI, no build/test/lint toolchain, no devDependencies.
# Deliberately slim and separate from the control-plane image (which bundles all
# of that for dev/orchestration).
FROM node:22-bookworm-slim

LABEL org.opencontainers.image.title="Forge Data Plane"
LABEL org.opencontainers.image.description="Forge production/runtime (data plane). No developer dependencies."
LABEL com.mardash-ai.plane="data"

WORKDIR /forge

# Production dependencies only — omits typescript, vitest, @types/* (devDependencies).
# tsx is a runtime dependency, so it stays.
COPY package.json package-lock.json* ./
RUN npm ci --omit=dev || npm install --omit=dev

COPY tsconfig.json ./
COPY src ./src

ENV PORT=3718
EXPOSE 3718
CMD ["./node_modules/.bin/tsx", "src/data-plane/server.ts"]
