#!/usr/bin/env bash
# Thin Forge CLI wrapper. It runs the CLI *inside* the platform container, which
# then calls the Forge HTTP API. The local machine only ever invokes Docker.
set -euo pipefail

cd "$(dirname "$0")"

# Ensure the platform is running.
if ! docker compose ps --status=running --services 2>/dev/null | grep -qx api; then
  echo "forge: platform not running — starting it (docker compose up -d --build)..." >&2
  docker compose up -d --build api >&2
  # Wait for the API to answer before handing off.
  for _ in $(seq 1 30); do
    if docker compose exec -T api node -e "fetch('http://localhost:3717/health').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))" 2>/dev/null; then
      break
    fi
    sleep 1
  done
fi

# The `--` after `tsx` is load-bearing (P16): tsx hoists ANY node CLI flag it finds
# anywhere in argv — even after the script — into the underlying node process. Without
# the separator, `forge deploy … --env-file app/.env.prod` hands `--env-file` to NODE,
# which resolves it against the container CWD (`/forge`, no app files) and aborts at
# startup with `node: app/.env.prod: not found` before the CLI ever runs. `--` tells tsx
# everything after is the script + its args, so the operator's flags reach forge's own
# parser and resolve against FORGE_WORKSPACE (where Compose runs). Do NOT remove it.
exec docker compose exec -T \
  -e FORGE_API_URL=http://localhost:3717 \
  api ./node_modules/.bin/tsx -- src/cli/index.ts "$@"
