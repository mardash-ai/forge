# C36 — Langfuse self-host secrets
# Copy this file to .env.langfuse, fill in EVERY value with a real random secret,
# then start the observability profile:
#
#   docker compose --env-file .env.langfuse --profile observability up -d
#
# Generate randoms (32-char hex):
#   node -e "const { randomBytes } = require('crypto'); console.log(randomBytes(32).toString('hex'))"
#
# After starting, register with forge:
#   forge setup-observability \
#     --public_key <LANGFUSE_PUBLIC_KEY> \
#     --secret_key <LANGFUSE_SECRET_KEY>

# ── Postgres (Langfuse-own DB — NOT the dorinda domain Postgres) ───────────
LANGFUSE_PG_PASSWORD=changeme_replace_with_random_32chars

# ── Redis / Valkey ─────────────────────────────────────────────────────────
LANGFUSE_REDIS_PASSWORD=changeme_replace_with_random_32chars

# ── ClickHouse ─────────────────────────────────────────────────────────────
LANGFUSE_CLICKHOUSE_PASSWORD=changeme_replace_with_random_32chars

# ── MinIO blob store ───────────────────────────────────────────────────────
LANGFUSE_MINIO_ACCESS_KEY=changeme_replace_with_random_20chars
LANGFUSE_MINIO_SECRET_KEY=changeme_replace_with_random_40chars

# ── Langfuse web auth ──────────────────────────────────────────────────────
LANGFUSE_NEXTAUTH_SECRET=changeme_replace_with_random_32chars
LANGFUSE_SALT=changeme_replace_with_random_32chars
# Must be exactly 32 characters (AES-256 key)
LANGFUSE_ENCRYPTION_KEY=changeme_replace_with_exactly_32ch

# ── Bootstrap: Langfuse admin user ─────────────────────────────────────────
LANGFUSE_ADMIN_EMAIL=admin@forge.local
LANGFUSE_ADMIN_PASSWORD=changeme_replace_with_strong_password

# ── Bootstrap: OTLP API key pair (used by the forge OTel helper + forge setup-observability) ──
# These seed the default project's public/secret key pair on first start.
# They are also what you pass to `forge setup-observability`.
LANGFUSE_PUBLIC_KEY=pk-lf-changeme_replace_with_random
LANGFUSE_SECRET_KEY=sk-lf-changeme_replace_with_random

# ── UI host port (mapped to container :3000) ───────────────────────────────
LANGFUSE_UI_PORT=3100

# ── NextAuth URL (update to your public host when behind Traefik) ──────────
LANGFUSE_NEXTAUTH_URL=http://localhost:3100

# ── OTel exporter env (set in dorinda-api / any consumer) ─────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://langfuse-web:3000/api/public/otel
# LANGFUSE_PUBLIC_KEY=<same as above>
# LANGFUSE_SECRET_KEY=<same as above>
